{
  "_comment": "FreqTop output and visualisation configuration",

  "run": {
    "method": "BOTH",
    "solver": "topopt"
  },

  "output": {
    "folder": "results_beam_clamped_testfont"
  },

  "sweep": {
    "_comment": "Set enabled=true to loop over values. Each entry overrides parameters.json using dot-notation paths.",
    "enabled": false,
    "values": [
      {"domain.mesh.nelx": 100,  "domain.mesh.nely": 10},
      {"domain.mesh.nelx": 200,  "domain.mesh.nely": 20}
    ],
    "comparison_table": {
      "enabled": true,
      "filename": "comparison_table.tsv"
    }
  },

  "plots": {
    "density": {
      "enabled": false
    },
    "convergence": {
      "enabled": true
    },
    "change_norm": {
      "enabled": true
    },
    "volume_fraction": {
      "enabled": false
    },
    "stage_breakdown": {
      "enabled": false
    },
    "change_vs_cumtime": {
      "enabled": true,
      "_comment_tol": "Horizontal tolerance lines drawn on change_vs_cumtime and change_vs_iteration plots.",
      "tol_values": [1e-2, 1e-3, 1e-4]
    },
    "change_vs_iteration": {
      "enabled": true,
      "tol_values": [1e-2, 1e-3, 1e-4]
    },
    "cumulative_time": {
      "enabled": false
    },
    "cumulative_memory": {
      "enabled": false
    },
    "obj_vs_cumtime": {
      "enabled": false
    },
    "comparison": {
      "enabled": false
    },
    "density_animation": {
      "enabled": true
    },
    "density_animation_singleframes": {
      "enabled": true
    },
    "cumtime_animation": {
      "enabled": true
    }
  },

  "csv": {
    "enabled": true,
    "description": "Tab-separated export — one file per method: oc_data.csv, sqp_data.csv",
    "columns": {
      "method":               true,
      "iteration":            true,
      "time_s":               true,
      "cumulative_time_s":    true,
      "memory_mb":            true,
      "cumulative_memory_mb": true,
      "objective_f":          true,
      "change":               true
    }
  },

  "style": {
    "dpi":              150,
    "fig_size":         [9.0, 5.5],
    "font_family":      "Times New Roman",
    "font_size":        11,
    "title_font_size":  28,
    "label_font_size":  13,
    "tick_font_size":   11,
    "cbar_font_size":   9,
    "show_grid":        true,
    "density_cmap":     "gray",
    "animation_fps":    5,
    "animation_format": "gif"
  }
}
